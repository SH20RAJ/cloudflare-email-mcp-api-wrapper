# Worker endpoint for test script
WORKER_URL=https://your-worker-name.workers.dev

# Optional protection token configured in the worker as API_TOKEN
WORKER_API_TOKEN=your_worker_api_token

# Legacy direct Cloudflare API flow only
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Email payload defaults for local test script
TEST_TO=recipient@example.com
TEST_FROM=noreply@yourdomain.com
TEST_SUBJECT=Test Email from CF Email MCP API
